# Root / shared development defaults
COMPOSE_PROJECT_NAME=darna

# API
APP_NAME=Darna
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

# Database
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=darna
DB_USERNAME=darna
DB_PASSWORD=darna_secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Sanctum / CORS
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Reverb
REVERB_APP_ID=darna
REVERB_APP_KEY=darna-reverb-key
REVERB_APP_SECRET=darna-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_REVERB_KEY=darna-reverb-key
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http
NEXT_PUBLIC_BRANCH_SLUG=downtown
